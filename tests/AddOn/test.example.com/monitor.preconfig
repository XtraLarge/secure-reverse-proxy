# monitor.preconfig — metrics dashboard reverse proxy headers
#
# Some dashboards need to know their public URL to generate correct absolute links,
# redirects, and cookie paths. Without these headers the backend may redirect the
# browser to its internal backend address (e.g. http://10.0.0.4:3000/).
#
# The proxy passes the public hostname and protocol to the backend so it can
# build correct URLs even if the root URL is not explicitly configured there.

RequestHeader set X-Forwarded-Proto "https"
RequestHeader set X-Forwarded-Host  "%{HTTP_HOST}s"
ProxyPreserveHost On
