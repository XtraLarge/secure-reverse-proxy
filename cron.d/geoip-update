# Weekly GeoIP2 database update (every Wednesday at 04:30)
# Only runs if GEOIP_ACCOUNT_ID and GEOIP_LICENSE_KEY are configured.
# See /etc/GeoIP.conf for configuration.
30 4 * * 3 root test -f /etc/GeoIP.conf && grep -q "^AccountID [^0]" /etc/GeoIP.conf && geoipupdate -v 2>&1 | logger -t geoipupdate
